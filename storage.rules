rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/contracts/{contractId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/icons/{folder}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
