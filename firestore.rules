rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // Subscription fields are only ever written by the Stripe webhook, which uses
      // Admin SDK credentials and bypasses these rules entirely — block the client
      // from setting its own billing status directly.
      allow update: if isOwner(userId)
                     && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['subscriptionStatus', 'stripeCustomerId', 'stripeSubscriptionId']);

      match /accounts/{accountId} {
        allow read, write: if isOwner(userId);
      }
      match /cards/{cardId} {
        allow read, write: if isOwner(userId);
      }
      match /categories/{categoryId} {
        allow read, write: if isOwner(userId);
      }
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                       && request.resource.data.amountCents is int
                       && request.resource.data.amountCents > 0;
        allow update, delete: if isOwner(userId);
      }
      match /invoices/{invoiceId} {
        allow read, write: if isOwner(userId);
      }
      match /recurringRules/{ruleId} {
        allow read, write: if isOwner(userId);
      }
      match /contracts/{contractId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
